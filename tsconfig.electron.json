{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "outDir": "dist-electron",
    "esModuleInterop": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "types": ["node", "jest", "vite/client"]
  },
  "include": ["electron/**/*", "shared/**/*"]
}
